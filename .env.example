# Optional: disabled by default because the native scraper can fail in serverless/dev workers.
ENABLE_HIANIME_SCRAPER=false
NEXT_PUBLIC_ENABLE_HIANIME_SCRAPER=false

# Manga chapter providers.
# MangaHook is optional and must point to your own working server API.
# Comick Source API adds English chapter lists from sources AniFlex can scrape into its reader.
# GoManga is best-effort because its hosted scraper depends on an upstream manga site.
ENABLE_COMICK_SOURCE_PROVIDER=true
COMICK_SOURCE_API_BASE=https://comick-source-api.notaspider.dev
COMICK_SOURCE_IDS=MangaKatana,mangaread,asurascan,flamecomics,Vortex Scans
ENABLE_GOMANGA_PROVIDER=true
GOMANGA_API_BASE=https://gomanga-api.vercel.app
XBATO_API_BASE=https://xbato-api.hanifu.id
MANGA_PROVIDER_TIMEOUT_MS=8000
# MANGAHOOK_API_BASE=http://127.0.0.1:3000/api
